#!/bin/sh
set -e

PACKAGER="libdxrt"
SRC_DIR="/usr/share/${PACKAGER}"

cd "$SRC_DIR"

PYTHON_VERSION=$(python3 -c 'import sys; print(f"{sys.version_info[0]}.{sys.version_info[1]}")')
MAJOR_VERSION=$(echo "$PYTHON_VERSION" | cut -d. -f1)
MINOR_VERSION=$(echo "$PYTHON_VERSION" | cut -d. -f2)

# PEP 668 (externally-managed-environment) is enforced on Python >= 3.11
# in Debian/Ubuntu derivatives (Ubuntu 23.04+ ships 3.11, Ubuntu 24.04+ ships 3.12).
# pip >= 23.0 (bundled with those releases) supports --break-system-packages.
# Python < 3.11 (Ubuntu 22.04 with Python 3.10) has no PEP 668 and ships
# pip 22.x which does not recognise --break-system-packages, so skip the flag.
if [ "$MAJOR_VERSION" -eq 3 ] && [ "$MINOR_VERSION" -ge 11 ]; then
    ./build.sh --clean --python-break-system-packages
else
    ./build.sh --clean
fi
ldconfig

exit 0
