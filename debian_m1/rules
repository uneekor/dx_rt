#!/usr/bin/make -f

PACKAGER := libdxrt
DESTDIR := $(CURDIR)/debian/$(PACKAGER)

%:
	dh $@


override_dh_auto_build:
	@echo "Preparing to package local changes for $(PACKAGER)..."

override_dh_auto_install:
	# Create target directory
	mkdir -p $(DESTDIR)/usr/share/$(PACKAGER)

	# Copy all contents of the current directory to the package path
	# Use . and exclude the 'debian' directory to avoid recursive loops
	# pyproject.toml is kept as-is so that scikit-build-core can properly
	# build and include _pydxrt.so during postinst pip install.
	rsync -av --exclude='debian' --exclude='.git' --exclude='.github' --exclude='release' $(CURDIR)/ $(DESTDIR)/usr/share/$(PACKAGER)/

	@echo "Files synced to $(DESTDIR)"

override_dh_auto_clean:
	dh_auto_clean
	@echo "Cleaning up build artifacts..."